# 複製這個檔案為 .env 並填入你的金鑰
# 取得 Gemini API 金鑰：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 多把金鑰輪替（選填，優先於 GEMINI_API_KEY）：逗號分隔，
# 免費層每天每把 key 只有少量請求，撞到 429 會自動換下一把
# GEMINI_API_KEYS=key1,key2,key3

# LLM 型號（gemini-2.5-flash 對新帳號已停用；可用 gemini-flash-latest 自動跟最新版，
# 或展演前換 gemini-pro-latest 提高準確率）
GEMINI_MODEL=gemini-3.5-flash

# 轉錄後端：
#   local  = 本地 faster-whisper（需 NVIDIA GPU，本機開發用這個）
#   gemini = 用 Gemini 直接聽音訊轉錄（雲端無 GPU 時用；Dockerfile 已預設 gemini）
TRANSCRIBE_ENGINE=local

# Gemini 轉錄專用模型（只在 TRANSCRIBE_ENGINE=gemini 時有作用）。
# 轉錄吃掉絕大多數請求（即時聆聽每段一次）但不需要聰明模型，預設用
# 免費額度高的輕量版；分析仍走上面的 GEMINI_MODEL，品質不受影響
# TRANSCRIBE_MODEL=gemini-flash-lite-latest
#
# 多人會議的講者分辨：實測 flash-lite 對「誰在講話」的辨識不穩定，多位講者
# 常被併成一兩位。若你的錄音常有 3 人以上、需要準確標出講者，改用較強的
# 模型（免費每日額度較低）：
# TRANSCRIBE_MODEL=gemini-flash-latest

# Whisper 模型與裝置（只在 TRANSCRIBE_ENGINE=local 時有作用）。
# 留空 = 自動：有 CUDA 用 GPU+medium，否則 CPU+small
# 可選模型：tiny / base / small / medium / large-v3
WHISPER_MODEL=
WHISPER_DEVICE=

# 即時聆聽每段錄音的秒數（30~60 建議值）
LIVE_CHUNK_SECONDS=45

# 後臺資料庫（選填）：兩者都不填 = 本地 JSON（data/output/db.json，重啟會清空）；
# 填任一個就改用 Firebase Firestore 雲端持久化。取得金鑰：Firebase Console
# → 專案設定 → 服務帳戶 → 產生新的私密金鑰（下載 service account JSON）。
#   本機：指向下載的 JSON 檔路徑
# FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json
#   雲端（如 Render）：把整份 JSON 內容貼成單行字串
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
